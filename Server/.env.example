PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret

# Contact form: where to receive submissions
CONTACT_RECEIVING_EMAIL=hodge2023@outlook.com

# Resend (recommended for contact form emails)
# Get API key at https://resend.com/api-keys | From: verify domain or use onboarding@resend.dev
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=Evo Media <onboarding@resend.dev>

# Firebase Admin (for "Sign in with Google" / Firebase Auth)
# Option A: Service account JSON file path
# GOOGLE_APPLICATION_CREDENTIALS=./path-to-serviceAccountKey.json
# Option B: Env vars (from Firebase Console > Project Settings > Service Accounts)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: SMTP fallback if Resend is not used
# EMAIL_USER=your@email.com
# EMAIL_PASS=app_password
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
